# HTML always revalidated so updates are immediate
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

# Directory URLs (no .html extension) — must be explicit for Netlify
/studies/
  Cache-Control: no-cache, no-store, must-revalidate

/studies/hospitality/
  Cache-Control: no-cache, no-store, must-revalidate

/studies/places/
  Cache-Control: no-cache, no-store, must-revalidate

/studies/craft/
  Cache-Control: no-cache, no-store, must-revalidate

/studies/experience/
  Cache-Control: no-cache, no-store, must-revalidate

# CSS versioned via ?v= query string — revalidate on change
/css/style.css
  Cache-Control: no-cache, no-store, must-revalidate

# Images cached for 1 year — filenames change when content changes
/images/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: image/x-icon

/images/favicon-16.png
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: image/png

/images/favicon-32.png
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: image/png

/images/favicon-64.png
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: image/png

/images/favicon-180.png
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: image/png

/images/favicon-512.png
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: image/png

/site.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/manifest+json
